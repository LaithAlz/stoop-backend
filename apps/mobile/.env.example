# Stoop mobile — environment template
# Copy to apps/mobile/.env and fill in real values before running the app.
# NEVER commit .env (gitignored). Do not copy values from apps/api/.env by
# hand-editing this file into a real one with secrets — the mobile app only
# ever needs the two PUBLIC values below (the anon key is publishable by
# design; row-level security enforces access). The service-role key must
# never appear anywhere in this app.
#
# Values: Supabase dashboard -> Project Settings -> API.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
