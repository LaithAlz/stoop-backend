{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stoop-web",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "d1_databases": [
    {
      "binding": "WAITLIST_DB",
      "database_name": "stoop-waitlist",
      "database_id": "REPLACE_WITH_D1_ID", // run: bunx wrangler d1 create stoop-waitlist
      "migrations_dir": "migrations",
    },
  ],
}
