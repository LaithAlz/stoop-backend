# Stoop API — environment variable template
# Copy this file to .env and fill in real values before running locally.
# See docs/setup/supabase.md for how to obtain the Supabase values.
# NEVER commit .env — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Database (Supabase connection pooler — Transaction mode, port 6543)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:6543/postgres
# The transaction pooler (port 6543) is fully supported, including Alembic migrations — see app/db/session.py.

# Optional: request-path connection string using the app_role login (RLS, #22).
# Leave unset until the one-time operator step (ALTER ROLE app_role LOGIN
# PASSWORD '...' run directly against the database, then set this secret) is
# done -- see app/db/session.py's module docstring. Unset = request sessions
# fall back to the admin engine (DATABASE_URL above); RLS is not yet enforced
# by role separation, logged once at startup, no secrets in that log line.
# APP_DATABASE_URL=postgresql+asyncpg://app_role.PROJECT_REF:PASSWORD@HOST:6543/postgres

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://YOUR_PROJECT.supabase.co/auth/v1
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------------------------------------------------------
# Twilio (webhook signature verification — #40/#152; outbound sends — #108)
# ---------------------------------------------------------------------------
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
# Account SID for the outbound REST client (app/integrations/twilio_send.py).
# Used ONLY by the emergency escalation chain (#108) today.
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
# Optional: the public HTTPS origin Twilio is configured to POST to (proxy
# -aware signature verification — see app/integrations/twilio.py). Leave
# unset locally; the webhook handler falls back to X-Forwarded-Proto/
# X-Forwarded-Host from the trusted proxy hop (Fly.io terminates TLS).
# PUBLIC_BASE_URL=https://api.stoop.example
# Optional: Twilio Messaging Service SID for automatic A2P 10DLC/CASL
# campaign association on newly-provisioned property numbers (#53). Leave
# unset -- A2P registration is still pending externally; provisioning works
# fine without it, just without the compliance association (logged, never
# fails provisioning).
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: hard cap on properties (= live Twilio numbers) per landlord
# (#53 safety review H1) -- a pre-Twilio-call spend guard, NOT a paywall
# (every landlord gets the same cap). Defaults to 25; leave unset locally.
# MAX_PROPERTIES_PER_LANDLORD=25

# ---------------------------------------------------------------------------
# Anthropic (agent — #26/#9+)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ---------------------------------------------------------------------------
# LangSmith (agent tracing — #26; optional, leave blank to disable tracing)
# ---------------------------------------------------------------------------
# There is no LangSmith account yet. Leave both unset/blank -- when
# LANGSMITH_API_KEY is unset, app/observability.py's init_langsmith_tracing()
# never exports any LANGSMITH_* env var and no tracing is attempted (no
# network calls, no import-time surprises). Once an account exists, set both
# and a hello-world LangGraph run will appear as a trace in LangSmith.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# ---------------------------------------------------------------------------
# Observability (optional — leave blank to disable Sentry)
# ---------------------------------------------------------------------------
SENTRY_DSN=
